# 复制为 .env 后填写真实值。.env 已在 .gitignore 中，不要提交。
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
# 单次生图应用层超时最高支持 999 秒；外层 Nginx/宝塔超时也需要同步放大。

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

SESSION_SECRET=
USER_API_KEY_SECRET=
STORAGE_DIR=

# PHP 配置文件只读取环境变量，真实密钥不要写入仓库。
# 生产环境需在 PHP-FPM / Web 服务器进程环境中设置这些值。